<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sparkle auto-updates. This partial plist merges into the generated
	     Info.plist (GENERATE_INFOPLIST_FILE stays on); it exists only to carry
	     keys Xcode has no INFOPLIST_KEY_ setting for. -->

	<!-- The appcast lives as an asset on the rolling "updates" GitHub release
	     (see scripts/release-macos.sh), so its URL never changes. -->
	<key>SUFeedURL</key>
	<string>https://github.com/Nicolas-schimmelpfennig/BetterContentLibrary/releases/download/updates/appcast.xml</string>

	<!-- EdDSA public key; updates must be signed by the matching private key
	     (in the login Keychain of the release machine, account "ed25519"). -->
	<key>SUPublicEDKey</key>
	<string>nU5/Jpn14faKH4pXUHPIaKbrmq3yNAEzebMpTKttsVI=</string>

	<!-- Required for Sparkle to install updates from inside the app sandbox. -->
	<key>SUEnableInstallerLauncherService</key>
	<true/>

	<!-- Invite deep links: bettercontent://join?code=XXXXXXXX opens the join
	     sheet (see OrgInviteLink + RootView.onOpenURL). -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>Nicolas.BetterContentLibrary.invite</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>bettercontent</string>
			</array>
		</dict>
	</array>

	<!-- Makes the iCloud container's Documents folder visible in Finder/Files
	     as "BetterContentLibrary", so users can see their stored clips. -->
	<key>NSUbiquitousContainers</key>
	<dict>
		<key>iCloud.Nicolas.BetterContentLibrary</key>
		<dict>
			<key>NSUbiquitousContainerIsDocumentScopePublic</key>
			<true/>
			<key>NSUbiquitousContainerName</key>
			<string>BetterContentLibrary</string>
			<key>NSUbiquitousContainerSupportedFolderLevels</key>
			<string>Any</string>
		</dict>
	</dict>
</dict>
</plist>
