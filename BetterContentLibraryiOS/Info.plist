<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Partial plist merged into the generated Info.plist
	     (GENERATE_INFOPLIST_FILE stays on); it exists only to carry keys
	     Xcode has no INFOPLIST_KEY_ setting for. -->

	<!-- Invite deep links: bettercontent://join?code=XXXXXXXX opens the join
	     sheet (see OrgInviteLink + RootView.onOpenURL). -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>Nicolas.BetterContentLibrary.iOS.invite</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>bettercontent</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
